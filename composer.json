{
  "require": {
    "firebase/php-jwt": "^7.0",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^7.0",
    "zircote/swagger-php": "^6.1",
    "symfony/console": "^7.4"
  },
  "autoload": {
    "classmap": [
      "controllers/",
      "config/",
      "models/",
      "DTO/",
      "middleware/",
      "base/",
      "utils/"
    ]
  },
"scripts": {
  "swagger": "vendor/bin/openapi.bat -b vendor/autoload.php controllers config/docs -o swagger.yaml"
}
}
